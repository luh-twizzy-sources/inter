<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.13.xsd
                      http://www.liquibase.org/xml/ns/dbchangelog-ext
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="001-create-payment-collection" author="Yafimchyk">
        <ext:createCollection collectionName="payment"/>

        <ext:createIndex collectionName="payment">
            <ext:keys>{order_id: 1}</ext:keys>
            <ext:options>{name: "idx_payment_order_id"}</ext:options>
        </ext:createIndex>

        <ext:createIndex collectionName="payment">
            <ext:keys>{user_id: 1}</ext:keys>
            <ext:options>{name: "idx_payment_user_id"}</ext:options>
        </ext:createIndex>

        <ext:createIndex collectionName="payment">
            <ext:keys>{status: 1}</ext:keys>
            <ext:options>{name: "idx_payment_status"}</ext:options>
        </ext:createIndex>

        <ext:createIndex collectionName="payment">
            <ext:keys>{timestamp: -1}</ext:keys>
            <ext:options>{name: "idx_payment_timestamp"}</ext:options>
        </ext:createIndex>
    </changeSet>
</databaseChangeLog>